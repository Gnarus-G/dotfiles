#!/usr/bin/env python3

import json
import os
import shutil
import subprocess
from pathlib import Path

DOTFILES = Path(__file__).resolve().parent
HOME = Path.home()

# source dir (relative to dotfiles repo) -> list of symlink targets (relative to ~)
# Most map 1:1 to the same relative path under ~.
LINKS: dict[str, list[str]] = {
    # ~/.agents/skills is a real dir holding per-skill symlinks into the repo.
    **{
        f".agents/skills/{d.name}": [
            f".agents/skills/{d.name}",
