        ]
        for d in sorted((DOTFILES / ".agents" / "skills").iterdir())
        if d.is_dir()
    },
    **{
        f".claude/skills/{d.name}": [f".claude/skills/{d.name}"]
        for d in sorted((DOTFILES / ".claude" / "skills").iterdir())
        if d.is_dir()
    },
    ".config/nvim": [".config/nvim"],
    ".config/mcphub": [".config/mcphub"],
    ".config/opencode": [".config/opencode"],
