def show_diff(source: Path, target: Path):
    """Show a diff between the dotfiles source and the conflicting target."""
    # Resolve symlinks so we diff actual content
    real_target = target.resolve() if target.is_symlink() else target
    real_source = source.resolve() if source.is_symlink() else source

    if real_source.is_file() and real_target.is_file():
        subprocess.run(
            ["diff", "--color=always", "-u", str(real_source), str(real_target)],
            # diff exits 1 when files differ — that's expected
        )
    elif real_source.is_dir() and real_target.is_dir():
        subprocess.run(
            ["diff", "--color=always", "-ru", str(real_source), str(real_target)],
        )
    else:
        print(f"    (cannot diff: {real_source} and {real_target} are different types)")


def prompt_conflict(source: Path, target: Path) -> str:
    """Ask the user how to resolve a conflict at target."""
    print(f"\n  conflict: {target}")
    if target.is_symlink():
        print(f"    existing symlink -> {os.readlink(target)}")
        print(f"    expected         -> {source}")
    elif target.is_dir():
        print(f"    existing directory with content")
    else:
        print(f"    existing file")

    show_diff(source, target)

    while True:
        choice = input("  [o]verwrite / [a]bsorb / [s]kip? ").strip().lower()
        if choice in ("o", "overwrite"):
            return "overwrite"
        if choice in ("a", "absorb"):
            return "absorb"
        if choice in ("s", "skip"):
            return "skip"


def absorb(source: Path, target: Path):
    """Move the existing target content into the dotfiles repo, then symlink."""
    if source.exists() or source.is_symlink():
        # Merge: for dirs, copy tree contents over; for files, replace.
        if source.is_dir() and target.is_dir():
            try:
                shutil.copytree(target, source, dirs_exist_ok=True)
            except shutil.Error as e:
                # Python 3.14+ refuses to copy a file onto itself (e.g. when
                # the target contains hardlinks to the source). If every
                # colliding entry is a same-file copy, treat as already-synced.
                if shares_inode(source, target):
                    pass
                else:
                    raise
        else:
            if source.is_symlink():
                source.unlink()
            source.parent.mkdir(parents=True, exist_ok=True)
            shutil.move(str(target), str(source))
    else:
        source.parent.mkdir(parents=True, exist_ok=True)
        shutil.move(str(target), str(source))


def remove(target: Path):
    """Remove a target path (file, symlink, or directory)."""
    if target.is_symlink() or target.is_file():
        target.unlink()
    elif target.is_dir():
        shutil.rmtree(target)


def link(source: Path, target: Path):
    """Create a symlink: target -> source."""
    target.parent.mkdir(parents=True, exist_ok=True)
    target.symlink_to(source)


def same_location(left: Path, right: Path) -> bool:
    """Check whether paths name the same location, including through symlinked parents."""
    return left.absolute() == right.absolute() or left.resolve(strict=False) == right.resolve(
        strict=False
    )


def is_correct_link(source: Path, target: Path) -> bool:
    """Check if target is already a symlink pointing to source."""
    return target.is_symlink() and target.resolve() == source.resolve()


def _walk_files(root: Path):
    """Yield every file under root, following symlinks but not descending into dirs that are symlinks (we only want real files)."""
    if root.is_file() and not root.is_symlink():
        yield root
        return
    for path in root.rglob("*"):
        if path.is_file() and not path.is_symlink():
            yield path


def shares_inode(source: Path, target: Path) -> bool:
    """True iff every file in target is the same inode as the corresponding file in source.

    A target of hardlinks to the source files means the data is physically
    already in the dotfiles repo, so absorb would be a no-op (and Python 3.14's
    shutil.copytree refuses to copy a file onto itself). Detecting this lets
    us short-circuit to overwrite/relink without prompting.
    """
    if not source.exists() or not target.exists():
        return False
    if source.is_symlink() or target.is_symlink():
        return False

    source_files = list(_walk_files(source))
    target_files = list(_walk_files(target))
    if len(source_files) != len(target_files):
        return False

    source_inodes = {p.stat().st_ino for p in source_files}
    target_inodes = {p.stat().st_ino for p in target_files}
    return source_inodes == target_inodes and len(source_inodes) > 0


def main():
    print(f"dotfiles: {DOTFILES}")
    print(f"home:     {HOME}\n")

    for src_rel, dst_rels in LINKS.items():
        source = DOTFILES / src_rel
        for dst_rel in dst_rels:
            target = HOME / dst_rel

            # Never operate through a symlinked parent that resolves back into
            # the source tree; removing that target would remove the source.
            if same_location(target, source):
                print(f"  --  {dst_rel} (skipped: target == source)")
                continue

            # Already correct — nothing to do.
            if is_correct_link(source, target):
                print(f"  ok  {dst_rel}")
                continue

            # Nothing at target — just link.
            if not target.exists() and not target.is_symlink():
                link(source, target)
                print(f"  ln  {dst_rel}")
                continue

            # Target is a hardlink farm pointing at the source — the data is
            # already in the dotfiles repo. Replace the target with a real
            # symlink; nothing is lost.
            if shares_inode(source, target):
                remove(target)
                link(source, target)
                print(f"  ln  {dst_rel} (relinked hardlinks)")
                continue

            # Conflict: something is there that doesn't match.
            action = prompt_conflict(source, target)

            if action == "skip":
                print(f"  --  {dst_rel} (skipped)")
            elif action == "overwrite":
                remove(target)
                link(source, target)
                print(f"  ln  {dst_rel} (overwritten)")
            elif action == "absorb":
                absorb(source, target)
                remove(target)
                link(source, target)
                print(f"  ln  {dst_rel} (absorbed)")


def render_mcp_toml(servers: dict) -> str:
    """Render MCP server specs as Codex config TOML sections."""
    toml_blocks = []
    for name, spec in servers.items():
        lines = [f"[mcp_servers.{name}]"]
        lines.append(f'command = "{spec["command"]}"')
        if spec.get("args"):
            items = ", ".join(f'"{a}"' for a in spec["args"])
            lines.append(f"args = [{items}]")
        if spec.get("env"):
            lines.append(f"\n[mcp_servers.{name}.env]")
            for k, v in spec["env"].items():
                lines.append(f'{k} = "{v}"')
        toml_blocks.append("\n".join(lines))
    return "\n\n".join(toml_blocks)


def strip_mcp_sections(toml: str) -> str:
    """Remove existing Codex MCP sections while keeping unrelated config."""
    in_mcp = False
    kept = []
    for line in toml.splitlines():
        is_header = line.startswith("[")
        if is_header and "mcp_servers" in line:
            in_mcp = True
        elif is_header:
            in_mcp = False
        if not in_mcp:
            kept.append(line)
    return "\n".join(kept).strip()


def sync_claude_mcp(servers: dict):
    """Sync MCP servers into Claude Code."""
    if not shutil.which("claude"):
        print("  --  claude not found, skipping")
        return

    for name, spec in servers.items():
        subprocess.run(
            ["claude", "mcp", "add-json", "-s", "user", name, json.dumps(spec)],
            capture_output=True,
        )
        print(f"  mcp claude  {name}")


def sync_codex_mcp(servers: dict):
    """Merge MCP servers into ~/.codex/config.toml."""
    codex_target = HOME / ".codex" / "config.toml"
    mcp_toml = render_mcp_toml(servers)
    rest = strip_mcp_sections(codex_target.read_text()) if codex_target.exists() else ""

    content = mcp_toml
    if rest:
        content += "\n\n" + rest

    codex_target.parent.mkdir(parents=True, exist_ok=True)
    codex_target.write_text(content + "\n")
    print("  mcp codex  (synced)")


def sync_mcp():
    """Sync MCP servers from .mcp.json into Claude Code and Codex."""
    mcp_path = DOTFILES / ".mcp.json"
    if not mcp_path.exists():
        return

    servers = json.loads(mcp_path.read_text()).get("mcpServers", {})
    if not servers:
        return

    sync_claude_mcp(servers)
    sync_codex_mcp(servers)


def sync_opencode_skills():
    """Sync individual skills from .agents/skills to ~/.config/opencode/skills."""
    source_dir = DOTFILES / ".agents" / "skills"
    target_dir = HOME / ".config" / "opencode" / "skills"

    # Skills to exclude from OpenCode (already have plugin equivalents)
    EXCLUDED_SKILLS = {"tmux-processes"}

    if not source_dir.exists():
        return

    target_dir.mkdir(parents=True, exist_ok=True)

    for skill_dir in source_dir.iterdir():
        if not skill_dir.is_dir():
            continue

        skill_name = skill_dir.name

        # Skip excluded skills (have OpenCode plugin equivalents)
        if skill_name in EXCLUDED_SKILLS:
            print(f"  --  .config/opencode/skills/{skill_name} (excluded)")
            continue

        target_skill = target_dir / skill_name

        # Skip if target already exists (don't overwrite)
        if target_skill.exists() or target_skill.is_symlink():
            print(f"  ok  .config/opencode/skills/{skill_name}")
            continue

        # Create symlink for this skill
        target_skill.symlink_to(skill_dir)
        print(f"  ln  .config/opencode/skills/{skill_name}")


if __name__ == "__main__":
    main()
    sync_mcp()
    sync_opencode_skills()
