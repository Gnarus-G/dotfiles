{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "/tmp/**": "allow",
      "~/d/**": "allow"
    }
  },
  "autoupdate": true,
  "plugin": ["@different-ai/opencode-browser@4.6.1"],
  "instructions": ["~/d/dotfiles/.config/opencode/system.md"],
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {}
    }
  },
  "mcp": {
    "websearch": {
      "type": "local",
      "command": [
        "sh",
        "-c",
        "uv run --python 3.12 $HOME/.local/bin/ollama-websearch-mcp.py"
      ]
    }
  }
}
