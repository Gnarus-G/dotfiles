{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "/tmp/**": "allow",
      "~/d/**": "allow"
    }
  },
  "autoupdate": true,
  "plugin": ["opencode-agent-skills@0.6.4", "oh-my-opencode"],
  "instructions": ["~/d/dotfiles/.config/opencode/system.md"],
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "glm-5:cloud": {}
      }
    }
  },
  "mcp": {
    "tts": {
      "type": "local",
      "command": ["tts-mcp"],
      "environment": {
        "DBUS_SESSION_BUS_ADDRESS": "unix:path=/run/user/1000/bus",
        "HIMITHER_TTS_LOG_FILE": "/tmp/tts-mcp-server.log",
        "RUST_LOG": "debug",
        "XDG_RUNTIME_DIR": "/run/user/1000"
      }
    },
    "websearch": {
      "type": "local",
      "command": [
        "sh",
        "-c",
        "uv run --python 3.14 $HOME/.local/bin/ollama-websearch-mcp.py"
      ]
    }
  }
}
