#!/usr/bin/env python3
"""Prune stale local branches across repositories under a root directory."""

from __future__ import annotations

import argparse
import os
import re
import subprocess
import sys
import time
from dataclasses import dataclass, field
from pathlib import Path

HOME = str(Path.home())
PROTECTED_RE = re.compile(r"^(main|master)$")
REMOTE_ALLOW_RE = re.compile(r"^ghislain/")


@dataclass
class Config:
    root: str = os.environ.get("ROOT", f"{HOME}/d")
    days: int = int(os.environ.get("DAYS", "30"))
    worktree_allow_prefix: str = os.environ.get("WORKTREE_ALLOW_PREFIX", f"{HOME}/d/agentic/")
    execute: bool = False
    remote: bool = False
    prune_worktrees: bool = False


@dataclass
class Totals:
    candidates: int = 0
    deleted: int = 0
    remote_candidates: int = 0
    remote_deleted: int = 0
    skipped_dirty: int = 0
    worktrees_removed: int = 0
    worktrees_failed: int = 0


@dataclass(frozen=True)
class Branch:
    name: str
    timestamp: int


@dataclass
class RepoState:
    current_branch: str
    dirty: bool
    has_origin: bool
    worktree_by_branch: dict[str, str] = field(default_factory=dict)


def parse_args(argv: list[str]) -> Config:
    defaults = Config()
    if argv == ["help"]:
        argv = ["--help"]

    parser = argparse.ArgumentParser(
        prog="git prune-old-branches",
        description="Prune stale local branches across repositories under a root directory.",
    )
    parser.add_argument(
        "--execute",
        action="store_true",
        help="actually delete branches (default: dry-run)",
    )
    parser.add_argument(
        "--remote",
        action="store_true",
        help=f"also delete the branch on origin; only branches matching {REMOTE_ALLOW_RE.pattern} are pushed",
    )
    parser.add_argument(
        "--prune-worktrees",
        action="store_true",
        help=(
            f"remove linked worktrees under {defaults.worktree_allow_prefix} that hold a "
            "deletion-candidate branch, then delete; skips worktrees with uncommitted changes"
        ),
    )
    parser.add_argument(
        "--days",
        type=int,
        default=defaults.days,
        metavar="N",
        help="age threshold in days (default: %(default)s)",
    )
    parser.add_argument(
        "--root",
        default=defaults.root,
        metavar="DIR",
        help="directory to scan for repos (default: %(default)s)",
    )

    args = parser.parse_args(argv)
    return Config(
        root=args.root,
        days=args.days,
        worktree_allow_prefix=defaults.worktree_allow_prefix,
        execute=args.execute,
        remote=args.remote,
        prune_worktrees=args.prune_worktrees,
    )


def git(repo: str, *args: str, check: bool = False, capture: bool = True) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        ["git", "-C", repo, *args],
        check=check,
        stdout=subprocess.PIPE if capture else None,
        stderr=subprocess.STDOUT if capture else None,
        text=True,
    )


def display_path(path: str) -> str:
    home_prefix = f"{HOME}/"
    if path.startswith(home_prefix):
        return path[len(home_prefix) :]
    return path


def current_branch(repo: str) -> str:
    result = git(repo, "symbolic-ref", "--quiet", "--short", "HEAD")
    if result.returncode != 0:
        return ""
    return result.stdout.strip()


def is_dirty(repo: str) -> bool:
    diff = git(repo, "diff", "--quiet", "--ignore-submodules", "HEAD")
    if diff.returncode != 0:
        return True

    status = git(repo, "status", "--porcelain", "--untracked-files=no")
    return bool(status.stdout.strip())


def has_origin(repo: str, config: Config) -> bool:
    return config.remote and git(repo, "remote", "get-url", "origin").returncode == 0


def parse_worktrees(repo: str, config: Config) -> dict[str, str]:
    if not config.prune_worktrees:
        return {}

    result = git(repo, "worktree", "list", "--porcelain")
    worktree_by_branch: dict[str, str] = {}
    worktree_path = ""

    for line in result.stdout.splitlines():
        if line.startswith("worktree "):
            worktree_path = line.removeprefix("worktree ")
        elif line.startswith("branch refs/heads/"):
            branch = line.removeprefix("branch refs/heads/")
            if worktree_path.startswith(config.worktree_allow_prefix) and worktree_path != repo:
                worktree_by_branch[branch] = worktree_path
        elif line == "":
            worktree_path = ""

    return worktree_by_branch


def repo_state(repo: str, config: Config) -> RepoState:
    return RepoState(
        current_branch=current_branch(repo),
        dirty=is_dirty(repo),
        has_origin=has_origin(repo, config),
        worktree_by_branch=parse_worktrees(repo, config),
    )


def local_branches(repo: str) -> list[Branch]:
    result = git(repo, "for-each-ref", "--format=%(committerdate:unix)%09%(refname:short)", "refs/heads/")
    branches: list[Branch] = []

    for line in result.stdout.splitlines():
        if not line:
            continue

        timestamp, branch = line.split("\t", 1)
        branches.append(Branch(name=branch, timestamp=int(timestamp)))

    return branches


def branch_has_remote(repo: str, branch: str, state: RepoState) -> bool:
    if not state.has_origin or not REMOTE_ALLOW_RE.search(branch):
        return False

    return git(repo, "show-ref", "--verify", "--quiet", f"refs/remotes/origin/{branch}").returncode == 0


def remove_worktree(repo: str, worktree: str, totals: Totals) -> bool:
    result = git(repo, "worktree", "remove", worktree)
    if result.returncode == 0:
        print(f"  RM-WT {display_path(worktree)}")
        totals.worktrees_removed += 1
        return True

    print(f"  WT-FAIL {display_path(worktree)}")
    print(f"          {result.stdout.rstrip()}")
    totals.worktrees_failed += 1
    return False


def delete_local_branch(repo: str, branch: str, age_days: int, totals: Totals) -> bool:
    result = git(repo, "branch", "-D", branch)
    if result.returncode == 0:
        print(f"  DEL   {branch} ({age_days}d old)")
        totals.deleted += 1
        return True

    print(f"  FAIL  {branch} ({result.stdout.rstrip()})")
    return False


def push_remote_deletes(repo: str, remote_batch: list[str], totals: Totals) -> None:
    if not remote_batch:
        return

    print(f"  PUSH  origin --delete ({len(remote_batch)} branch(es))")
    result = git(repo, "push", "origin", "--delete", *remote_batch)
    if result.stdout:
        for line in result.stdout.rstrip().splitlines():
            print(f"    {line}")

    if result.returncode == 0:
        totals.remote_deleted += len(remote_batch)
    else:
        print("    (push partially or fully failed; check output above)")


def prune_repo(repo: str, config: Config, totals: Totals, cutoff: int, now: int) -> None:
    state = repo_state(repo, config)
    remote_batch: list[str] = []

    for branch in local_branches(repo):
        if PROTECTED_RE.search(branch.name):
            continue

        if branch.name == state.current_branch:
            if state.dirty:
                totals.skipped_dirty += 1
                print(f"  SKIP  {branch.name} (current branch, working tree dirty)")
            continue

        if branch.timestamp >= cutoff:
            continue

        age_days = (now - branch.timestamp) // 86400
        totals.candidates += 1

        has_remote_branch = branch_has_remote(repo, branch.name, state)
        if has_remote_branch:
            totals.remote_candidates += 1

        worktree = state.worktree_by_branch.get(branch.name, "")

        if config.execute:
            if worktree and not remove_worktree(repo, worktree, totals):
                print(f"  FAIL  {branch.name} (worktree blocks delete)")
                continue

            if delete_local_branch(repo, branch.name, age_days, totals) and has_remote_branch:
                remote_batch.append(branch.name)
        else:
            tags = ""
            if has_remote_branch:
                tags += " [+remote]"
            if worktree:
                tags += f" [+rm-wt: {display_path(worktree)}]"
            print(f"  WOULD {branch.name} ({age_days}d old){tags}")

    if config.execute:
        push_remote_deletes(repo, remote_batch, totals)


def iter_repos(config: Config) -> list[str]:
    root = Path(config.root)
    if not root.is_dir():
        return []

    repos: list[str] = []
    for entry in sorted(root.iterdir()):
        repo = str(entry)
        if not entry.is_dir() or not (entry / ".git").is_dir():
            continue
        if f"{repo}/".startswith(config.worktree_allow_prefix):
            continue
        repos.append(repo)

    return repos


def print_summary(config: Config, totals: Totals) -> None:
    print()
    if config.execute:
        print(f"Deleted {totals.deleted} local branch(es).", end="")
        if config.remote:
            print(f" Pushed delete for {totals.remote_deleted} remote branch(es).", end="")
        if config.prune_worktrees:
            print(
                f" Removed {totals.worktrees_removed} worktree(s) ({totals.worktrees_failed} failed).",
                end="",
            )
        print(f" Skipped {totals.skipped_dirty} dirty current branch(es).")
        return

    print(f"DRY RUN: {totals.candidates} local branch(es) would be deleted", end="")
    if config.remote:
        print(f" ({totals.remote_candidates} also on origin, marked [+remote])", end="")
    print(f". Skipped {totals.skipped_dirty} dirty current branch(es).")

    flags = ["--execute"]
    if config.remote:
        flags.append("--remote")
    if config.prune_worktrees:
        flags.append("--prune-worktrees")
    print(f"Re-run with {' '.join(flags)} to actually delete.")


def main() -> int:
    config = parse_args(sys.argv[1:])
    totals = Totals()
    now = int(time.time())
    cutoff = now - config.days * 86400

    for repo in iter_repos(config):
        print()
        print(f"== {display_path(repo)} ==")
        prune_repo(repo, config, totals, cutoff, now)

    print_summary(config, totals)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
