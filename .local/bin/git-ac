#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#   "ollama",
# ]
# ///

import argparse
import os
import shutil
import subprocess
import sys
import tempfile
import time
from dataclasses import dataclass
from pathlib import Path

try:
  from ollama import Client
except ImportError:
  Client = None


DEFAULT_OLLAMA_MODEL = "qwen3-coder-next:cloud"
OLLAMA_URL = "http://localhost:11434"

SYSTEM_PROMPT = """Write a high-quality git commit message for these staged changes.

Rules:
- Output only the commit message text.
- Subject line must be imperative, plain English, no type prefix, max 50 characters.
- Prefer the smallest accurate subject.
- Add a body only when it adds useful context.
- Body should explain intent or impact, not restate the diff.
- Avoid repeating obvious file names, symbols, or line-by-line edits.
- If the change is mechanical or self-evident, omit the body.
- No markdown, bullets, labels, or commentary.
"""


@dataclass(frozen=True)
class BackendConfig:
  backend: str
  model: str


def parse_args(argv: list[str]) -> argparse.Namespace:
  parser = argparse.ArgumentParser(
    prog="git ac",
    description="Generate a commit message using Ollama for staged changes.",
  )
  parser.add_argument("-y", "--no-edit", action="store_true", help="Skip editor, commit directly")
  parser.add_argument("-n", "--dry-run", action="store_true", help="Print generated message and exit")
  parser.add_argument(
    "-b",
    "--backend",
    choices=("ollama",),
    default="ollama",
    help="Generation backend (default: ollama)",
  )
  parser.add_argument("-m", "--model", help="Override Ollama model")
  parser.add_argument("-v", "--verbose", action="store_true", help="Show timing and quality metrics")
  return parser.parse_args(argv)


def resolve_backend_config(args: argparse.Namespace) -> BackendConfig:
  return BackendConfig(backend="ollama", model=args.model or DEFAULT_OLLAMA_MODEL)


def run_command(command: list[str], *, input_text: str | None = None) -> subprocess.CompletedProcess[str]:
  try:
    return subprocess.run(command, check=True, text=True, input=input_text, capture_output=True)
  except subprocess.CalledProcessError as exc:
    detail = (exc.stderr or exc.stdout or "").strip()
    if detail:
      raise SystemExit(detail) from exc
    raise SystemExit(f"Error: command failed: {' '.join(command)}") from exc


def git_output(args: list[str]) -> str:
  return run_command(["git", *args]).stdout


def staged_diff_args() -> list[str]:
  return ["diff", "--cached"]


def ensure_git_worktree() -> Path | None:
  result = subprocess.run(["git", "rev-parse", "--show-toplevel"], check=False, capture_output=True, text=True)
  if result.returncode != 0:
    return None
  return Path(result.stdout.strip()) if result.stdout.strip() else None


def ensure_staged_changes() -> None:
  worktree = ensure_git_worktree()
  if worktree is None:
    raise SystemExit("Error: Not inside a git worktree")
  os.chdir(worktree)
  result = subprocess.run(["git", *staged_diff_args(), "--quiet"], check=False)
  if result.returncode == 0:
    raise SystemExit("Error: No staged changes")
  if result.returncode != 1:
    raise SystemExit("Error: Unable to inspect staged changes")


def build_prompt(diff: str) -> str:
  return f"{SYSTEM_PROMPT}\nWrite a commit message for this Git diff:\n\n{diff}"


def get_prompt() -> str:
  return build_prompt(git_output(staged_diff_args()))


def get_ollama_client() -> Client:
  if Client is None:
    raise SystemExit("Error: Python package 'ollama' is not installed. Run this script with uv.")
  return Client(host=OLLAMA_URL)


def ollama_has_model(model: str) -> bool:
  try:
    data = get_ollama_client().list().model_dump()
  except Exception as exc:
    raise SystemExit(f"Error: Unable to reach Ollama at {OLLAMA_URL}: {exc}") from exc
  models = data.get("models", [])
  return any(item.get("model") == model or item.get("name") == model for item in models if isinstance(item, dict))


def ensure_ollama_model(model: str) -> None:
  if ollama_has_model(model):
    return
  if shutil.which("ollama") is None:
    raise SystemExit(f"Error: Model {model} not found and ollama CLI is unavailable")
  print(f"Model {model} not found. Pulling...", file=sys.stderr)
  subprocess.run(["ollama", "pull", model], check=True)


def generate_with_ollama(model: str, prompt: str) -> str:
  ensure_ollama_model(model)
  try:
    response = get_ollama_client().generate(model=model, prompt=prompt)
  except Exception as exc:
    raise SystemExit(f"Error: Ollama generate failed: {exc}") from exc
  message = getattr(response, "response", None)
  if not isinstance(message, str):
    raise SystemExit("Error: Ollama returned an unexpected response")
  return message.strip()


def print_verbose_header(config: BackendConfig, duration: float) -> None:
  print()
  print("---")
  print(f"Backend: {config.backend}")
  print(f"Model: {config.model}")
  print(f"Generation time: {duration:.2f}s")


def print_dry_run_metrics(message: str) -> None:
  lines = message.splitlines()
  subject = lines[0] if lines else ""
  body_lines = max(len(lines) - 2, 0)
  print(f"Subject line length: {len(subject)} chars")
  print(f"Body lines: {body_lines}")


def print_commit_metrics(message: str) -> None:
  subject = message.splitlines()[0] if message.splitlines() else ""
  print(f"Subject: {subject}")
  print(f"Subject length: {len(subject)} chars (limit: 50)")
  if len(subject) > 50:
    print("Warning: Subject exceeds 50 characters")
  prefixes = ("feat:", "fix:", "chore:", "refactor:", "test:", "docs:")
  if subject.startswith(prefixes):
    print("Warning: Subject has type prefix (should be plain imperative)")


def open_editor(path: Path) -> None:
  editor = os.environ.get("GIT_EDITOR") or os.environ.get("EDITOR") or "vi"
  if " " in editor:
    subprocess.run(f"{editor} {path}", shell=True, check=True)
  else:
    subprocess.run([editor, str(path)], check=True)


def commit_message(message: str, no_edit: bool) -> None:
  with tempfile.TemporaryDirectory() as tmpdir:
    message_path = Path(tmpdir) / "COMMIT_EDITMSG"
    message_path.write_text(message + "\n", encoding="utf-8")
    if not no_edit:
      open_editor(message_path)
    final_message = message_path.read_text(encoding="utf-8")
    if not final_message.strip():
      raise SystemExit("Aborting: empty commit message")
    subprocess.run(["git", "commit", "-F", str(message_path)], check=True)


def main(argv: list[str]) -> int:
  args = parse_args(argv)
  config = resolve_backend_config(args)
  ensure_staged_changes()
  prompt = get_prompt()

  start = time.perf_counter()
  message = generate_with_ollama(config.model, prompt)
  duration = time.perf_counter() - start

  if args.dry_run:
    print(message)
    if args.verbose:
      print_verbose_header(config, duration)
      print_dry_run_metrics(message)
    return 0

  commit_message(message, args.no_edit)
  if args.verbose:
    print_verbose_header(config, duration)
    print_commit_metrics(message)
  return 0


if __name__ == "__main__":
  raise SystemExit(main(sys.argv[1:]))
