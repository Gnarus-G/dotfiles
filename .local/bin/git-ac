#!/usr/bin/env python3
import argparse
import json
import logging
import os
import shutil
import subprocess
import sys
import tempfile
import time
import urllib.request

logger = logging.getLogger("git-ac")

OLLAMA_HOST = os.environ.get("OLLAMA_HOST", "http://localhost:11434")
OPENAI_API_KEY = os.environ.get("OPENAI_API_KEY", "")
OPENAI_BASE_URL = os.environ.get("OPENAI_BASE_URL", "https://api.openai.com/v1")
GNARUS_ALLOW_VENDOR_LLM = os.environ.get("GNARUS_ALLOW_VENDOR_LLM", "")

DEFAULT_MODEL_OLLAMA = "deepseek-v4-flash:cloud"
DEFAULT_MODEL_OPENAI = "gpt-5.4-nano"
DEFAULT_MODEL = DEFAULT_MODEL_OPENAI if GNARUS_ALLOW_VENDOR_LLM else DEFAULT_MODEL_OLLAMA

OLLAMA_PREFIXES = ("ollama/", "deepseek-", "qwen", "devstral")
OPENAI_PREFIXES = ("openai/", "gpt-", "o1", "o3", "o4")

PROMPT_TEMPLATE = """Generate a git commit message for these changes.

Format:
- Line 1: Subject (max 75 chars, imperative, no prefix)
- Line 2: Blank
- Line 3+: Body (explain what/why, wrap at 72 chars)

Do NOT include:
- Type prefixes (feat:, fix:, etc.)
- Markdown code blocks
- Explanations or commentary

Output ONLY the commit message.

Write a commit message for this Git diff:

{diff}"""


def detect_provider(model):
    if any(model.startswith(p) for p in OPENAI_PREFIXES) or model.startswith("openai/"):
        return "openai"
    return "ollama"


def strip_prefix(model):
    if model.startswith("openai/"):
        return model[len("openai/"):]
    return model


def http_request(url, data=None, headers=None):
    body = json.dumps(data).encode() if data else None
    hdrs = headers or {}
    if body and "Content-Type" not in hdrs:
        hdrs["Content-Type"] = "application/json"
    req = urllib.request.Request(url, data=body, headers=hdrs)
    with urllib.request.urlopen(req) as resp:
        return json.loads(resp.read().decode())


def ollama_request(path, data=None):
    url = f"{OLLAMA_HOST.rstrip('/')}{path}"
    return http_request(url, data)


def openai_request(path, data=None):
    url = f"{OPENAI_BASE_URL.rstrip('/')}/{path.lstrip('/')}"
    headers = {"Authorization": f"Bearer {OPENAI_API_KEY}"}
    return http_request(url, data, headers)


def model_exists(model):
    try:
        tags = ollama_request("/api/tags")
        return any(m["name"] == model for m in tags.get("models", []))
    except Exception:
        return False


def pull_model(model):
    logger.info("Model %s not found locally, pulling...", model)
    subprocess.run(["ollama", "pull", model], check=True)


def generate_message(model, diff_text):
    provider = detect_provider(model)
    logger.debug("Using provider=%s model=%s", provider, model)
    prompt = PROMPT_TEMPLATE.format(diff=diff_text)
    payload = {
        "model": strip_prefix(model),
        "stream": False,
        "messages": [{"role": "user", "content": prompt}],
    }

    start = time.perf_counter()
    match provider:
        case "openai":
            if not OPENAI_API_KEY:
                logger.error("OPENAI_API_KEY not set")
                sys.exit(1)
            payload["reasoning_effort"] = "none"
            resp = openai_request("/chat/completions", payload)
        case "ollama":
            payload["reasoning_effort"] = "none"
            resp = ollama_request("/v1/chat/completions", payload)

    elapsed = time.perf_counter() - start
    content = resp["choices"][0]["message"]["content"]
    logger.debug("Generated message in %.2fs (%d chars)", elapsed, len(content))
    return content, elapsed


def main():
    parser = argparse.ArgumentParser(
        prog="git-ac",
        description="Generate a commit message using Ollama for staged changes.",
    )
    parser.add_argument("-y", "--no-edit", action="store_true", help="Commit directly without editing")
    parser.add_argument("-n", "--dry-run", action="store_true", help="Print message, don't commit")
    parser.add_argument("-m", "--model", default=DEFAULT_MODEL, help=f"Model (default: {DEFAULT_MODEL})")
    parser.add_argument("-v", "--verbose", action="store_true", help="Show timing and quality metrics")
    parser.add_argument("-d", "--debug", action="store_true", help="Enable debug logging")
    args = parser.parse_args()

    log_level = logging.DEBUG if args.debug else logging.WARNING
    logging.basicConfig(level=log_level, format="%(name)s: %(message)s")

    if subprocess.run(["git", "diff", "--staged", "--quiet"]).returncode == 0:
        logger.error("No staged changes")
        sys.exit(1)

    diff_text = subprocess.run(["git", "diff", "--staged"], capture_output=True, text=True).stdout
    logger.debug("Diff size: %d bytes", len(diff_text))

    provider = detect_provider(args.model)
    if provider == "ollama" and not model_exists(args.model):
        pull_model(args.model)

    message, elapsed = generate_message(args.model, diff_text)

    if args.dry_run:
        logger.info(message)
        if args.verbose:
            subject = message.split("\n", 1)[0]
            body_lines = message.split("\n")[2:] if "\n\n" in message else []
            logger.info("")
            logger.info("---")
            logger.info("Provider: %s", provider)
            logger.info("Model: %s", args.model)
            logger.info("Generation time: %.2fs", elapsed)
            logger.info("Subject line length: %d chars", len(subject))
            logger.info("Body lines: %d", len(body_lines))
        sys.exit(0)

    tmpdir = tempfile.mkdtemp()
    try:
        tmpfile = os.path.join(tmpdir, "COMMIT_EDITMSG")
        with open(tmpfile, "w") as f:
            f.write(message)

        if not args.no_edit:
            editor = os.environ.get("GIT_EDITOR") or os.environ.get("EDITOR", "vi")
            subprocess.run(f"{editor} {tmpfile}", shell=True, check=True)

        if os.path.getsize(tmpfile) == 0:
            logger.error("Empty commit message, aborting")
            sys.exit(1)

        subprocess.run(["git", "commit", "-F", tmpfile], check=True)
    finally:
        shutil.rmtree(tmpdir, ignore_errors=True)

    if args.verbose:
        subject = message.split("\n", 1)[0]
        logger.info("")
        logger.info("---")
        logger.info("Provider: %s", provider)
        logger.info("Model: %s", args.model)
        logger.info("Generation time: %.2fs", elapsed)
        logger.info("Subject: %s", subject)
        logger.info("Subject length: %d chars (limit: 75)", len(subject))
        if len(subject) > 75:
            logger.warning("Subject exceeds 75 characters")
        if any(subject.startswith(p) for p in ("feat:", "fix:", "chore:", "refactor:", "test:", "docs:")):
            logger.warning("Subject has type prefix (should be plain imperative)")


if __name__ == "__main__":
    main()# test
